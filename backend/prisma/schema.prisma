generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum UserRole {
  anonymous
  basic
  advanced
  admin
}

enum ContentStatus {
  proposed
  final
}

enum SlideType {
  text
  link
  image
  gallery
}

enum VoteDirection {
  up
  down
}

model User {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String?  @unique @db.VarChar(255)
  displayName String?  @map("display_name") @db.VarChar(100)
  avatarUrl   String?  @map("avatar_url")
  role        UserRole @default(anonymous)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  sessions Session[]
  votes    Vote[]

  @@map("users")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Episode {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String   @unique @db.VarChar(50)
  title     String   @db.VarChar(255)
  date      String?  @db.VarChar(50)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  segments Segment[]

  @@map("episodes")
}

model Segment {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  episodeId String        @map("episode_id") @db.Uuid
  slug      String        @db.VarChar(100)
  name      String        @db.VarChar(255)
  status    ContentStatus @default(proposed)
  sortOrder Int           @default(0) @map("sort_order")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  slides  Slide[]

  @@unique([episodeId, slug])
  @@map("segments")
}

model Slide {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  segmentId String        @map("segment_id") @db.Uuid
  type      SlideType
  title     String        @db.VarChar(500)
  url       String?
  notes     String?
  details   String?
  status    ContentStatus @default(proposed)
  bullets   Json          @default("[]")
  sortOrder Int           @default(0) @map("sort_order")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  segment Segment      @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  images  SlideImage[]
  votes   Vote[]

  @@map("slides")
}

model SlideImage {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slideId   String  @map("slide_id") @db.Uuid
  src       String
  alt       String? @db.VarChar(255)
  sortOrder Int     @default(0) @map("sort_order")

  slide Slide @relation(fields: [slideId], references: [id], onDelete: Cascade)

  @@map("slide_images")
}

model Vote {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slideId   String        @map("slide_id") @db.Uuid
  userId    String?       @map("user_id") @db.Uuid
  direction VoteDirection
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  slide Slide @relation(fields: [slideId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@index([slideId])
  @@map("votes")
}

// ─────────────────────────── AI AGENT SYSTEM ───────────────────────────

enum LlmProvider {
  openai
  anthropic
  google
}

enum MessageRole {
  user
  assistant
  system
  tool
}

enum AgentDocType {
  soul
  memory
  context
  daily
}

model Agent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(100)
  description  String   @db.Text
  instructions String   @db.Text
  defaultModel String?  @map("default_model") @db.VarChar(100)
  features     Json     @default("{}")
  branding     Json     @default("{}")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  conversations     Conversation[]
  agentDocuments    AgentDocument[]
  memoryEmbeddings  AgentMemoryEmbedding[]
  kbDocuments       KBDocument[]
  kbDocumentChunks  KBDocumentChunk[]
  agentCapabilities AgentCapability[]

  @@map("agents")
}

model Conversation {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicId     String   @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  agentId      String   @map("agent_id") @db.Uuid
  sessionToken String?  @map("session_token") @db.VarChar(255)
  title        String?  @db.VarChar(255)
  messageCount Int      @default(0) @map("message_count")
  lastMessageAt DateTime? @map("last_message_at") @db.Timestamptz()
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([agentId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String      @map("conversation_id") @db.Uuid
  role           MessageRole
  content        String      @db.Text
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model AgentDocument {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId   String       @map("agent_id") @db.Uuid
  docType   AgentDocType @map("doc_type")
  docKey    String       @map("doc_key") @db.VarChar(255)
  content   String       @db.Text
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  agent      Agent                  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  embeddings AgentMemoryEmbedding[]

  @@unique([agentId, docType, docKey])
  @@index([agentId])
  @@map("agent_documents")
}

model AgentMemoryEmbedding {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  docId       String  @map("doc_id") @db.Uuid
  agentId     String  @map("agent_id") @db.Uuid
  chunkText   String  @map("chunk_text") @db.Text
  embedding   Unsupported("vector(1536)")?
  lineStart   Int?    @map("line_start")
  lineEnd     Int?    @map("line_end")
  contentHash String? @map("content_hash") @db.VarChar(64)

  document AgentDocument @relation(fields: [docId], references: [id], onDelete: Cascade)
  agent    Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([docId])
  @@index([agentId])
  @@map("agent_memory_embeddings")
}

model KBDocument {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId    String   @map("agent_id") @db.Uuid
  name       String   @db.VarChar(500)
  sourceType String   @default("text") @map("source_type") @db.VarChar(50)
  content    String?  @db.Text
  metadata   Json     @default("{}")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  agent  Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  chunks KBDocumentChunk[]

  @@index([agentId])
  @@map("kb_documents")
}

model KBDocumentChunk {
  id         String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String                          @map("document_id") @db.Uuid
  agentId    String                          @map("agent_id") @db.Uuid
  chunkIndex Int                             @map("chunk_index")
  content    String                          @db.Text
  embedding  Unsupported("vector(1536)")?
  tokenCount Int?                            @map("token_count")

  document KBDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  agent    Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([agentId])
  @@map("kb_document_chunks")
}

enum CapabilityType {
  bundled
  external
}

model Capability {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String         @db.VarChar(255)
  slug        String         @unique @db.VarChar(100)
  description String?        @db.Text
  type        CapabilityType @default(bundled)
  serverUrl   String?        @map("server_url")
  config      Json           @default("{}")
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  agentCapabilities AgentCapability[]

  @@map("capabilities")
}

model AgentCapability {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId      String   @map("agent_id") @db.Uuid
  capabilityId String   @map("capability_id") @db.Uuid
  config       Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  agent      Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@unique([agentId, capabilityId])
  @@map("agent_capabilities")
}

model LlmConfig {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider  LlmProvider
  model     String      @db.VarChar(100)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("llm_configs")
}

model LlmApiKey {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider     LlmProvider
  encryptedKey String      @map("encrypted_key") @db.Text
  keyPrefix    String?     @map("key_prefix") @db.VarChar(20)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([provider])
  @@map("llm_api_keys")
}
